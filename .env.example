# Database
DATABASE_URL=postgresql://crm_user:crm_secret_password@localhost:5432/crm_db

# Redis
REDIS_URL=redis://:crm_redis_secret@localhost:6379

# JWT — CHANGE IN PRODUCTION (min 32 chars random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
